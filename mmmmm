<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ISO 9001:2015 — Curso Completo</title>
<script src="scorm_api.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:'Segoe UI',Arial,sans-serif}
body{background:#1a1a2e;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:flex-start}

/* HEADER */
.top-bar{width:100%;background:#0d1117;border-bottom:1px solid #1e3a5f;padding:10px 20px;display:flex;align-items:center;justify-content:space-between}
.top-logo{font-size:14px;font-weight:700;color:#fff}.top-logo span{color:#4A90D9}
.top-unit{font-size:12px;color:#4b6a8a;font-weight:600}
.top-prog{display:flex;align-items:center;gap:8px}
.top-pbar{width:120px;height:4px;background:#1e2a3a;border-radius:99px}
.top-pfill{height:100%;background:#4A90D9;border-radius:99px;transition:width 0.4s}
.top-pct{font-size:11px;color:#4A90D9;font-weight:700}

/* VIEWER */
.viewer{width:100%;max-width:900px;margin:0 auto;padding:16px 16px 0;position:relative}

/* SLIDE DISPLAY */
.slide-display{position:relative;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.5);min-height:460px;display:flex;align-items:stretch}

/* ARROW BUTTONS */
.arr-btn{position:absolute;top:50%;transform:translateY(-50%);z-index:50;width:44px;height:44px;border-radius:50%;background:rgba(0,0,0,0.55);border:1.5px solid rgba(255,255,255,0.2);color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;backdrop-filter:blur(4px)}
.arr-btn:hover{background:rgba(74,144,217,0.8);border-color:#4A90D9}
.arr-btn:disabled{opacity:0.2;cursor:default}
.arr-btn.left{left:-22px}
.arr-btn.right{right:-22px}

/* SLIDES */
.slide{display:none;width:100%;animation:sldIn 0.35s both;flex-direction:column}
.slide.on{display:flex}
@keyframes sldIn{0%{opacity:0;transform:translateX(24px)}100%{opacity:1;transform:translateX(0)}}
@keyframes sldInR{0%{opacity:0;transform:translateX(-24px)}100%{opacity:1;transform:translateX(0)}}
.slide.rev{animation:sldInR 0.35s both}

/* SLIDE TYPES */

/* PORTADA */
.sl-portada{background:#1B3F6E;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 32px;text-align:center;min-height:460px}
.sl-portada-badge{background:rgba(74,144,217,0.25);border:1px solid #4A90D9;color:#7EB8F7;font-size:12px;font-weight:700;padding:5px 18px;border-radius:99px;letter-spacing:1px;margin-bottom:20px;display:inline-block}
.sl-portada-title{font-size:32px;font-weight:800;color:#fff;line-height:1.2;margin-bottom:12px}
.sl-portada-title span{color:#4A90D9}
.sl-portada-sub{font-size:15px;color:#B8D4F0;line-height:1.65;max-width:480px;margin:0 auto 28px}
.sl-portada-units{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:32px}
.sl-pu{background:rgba(255,255,255,0.07);border:1px solid rgba(74,144,217,0.35);border-radius:10px;padding:10px 16px;text-align:left}
.sl-pu-n{font-size:11px;color:#7EB8F7;font-weight:700;margin-bottom:2px}
.sl-pu-t{font-size:13px;color:#fff;font-weight:500}
.sl-portada-info{font-size:12px;color:#4b6a8a;display:flex;gap:20px;justify-content:center}

/* INTRO UNIDAD */
.sl-intro{background:#1B3F6E;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:36px 32px;min-height:460px}
.sl-intro-line{display:flex;align-items:center;width:100%;max-width:440px;margin-bottom:36px}
.sl-intro-bar{height:3px;background:#4A90D9;flex:1}
.sl-intro-num{width:72px;height:72px;border-radius:50%;background:#4A90D9;display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:800;color:#fff;flex-shrink:0}
.sl-intro-dot{width:14px;height:14px;border-radius:50%;background:#4A90D9;flex-shrink:0}
.sl-intro-body{display:flex;align-items:center;gap:24px;max-width:500px;width:100%}
.sl-intro-ico{width:110px;height:110px;border-radius:50%;background:rgba(74,144,217,0.18);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sl-intro-text .lbl{font-size:12px;color:#7EB8F7;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
.sl-intro-text h2{font-size:24px;font-weight:800;color:#fff;line-height:1.3;margin-bottom:8px}
.sl-intro-text p{font-size:14px;color:#B8D4F0;line-height:1.6}
.sl-intro-objs{margin-top:24px;max-width:460px;width:100%}
.sl-intro-objs-t{font-size:11px;color:#7EB8F7;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.sl-intro-obj{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:#B8D4F0;line-height:1.5;margin-bottom:6px}
.sl-intro-obj-chk{width:16px;height:16px;border-radius:50%;background:rgba(74,144,217,0.3);border:1.5px solid #4A90D9;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}

/* CONTENIDO */
.sl-content{flex:1;padding:28px 32px;display:flex;flex-direction:column;min-height:460px}
.sl-tag{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#4A90D9;margin-bottom:5px}
.sl-title{font-size:22px;font-weight:800;color:#1B3F6E;margin-bottom:4px;line-height:1.3}
.sl-sub{font-size:13px;color:#64748b;margin-bottom:14px;line-height:1.5}
.sl-div{height:3px;width:44px;background:#4A90D9;border-radius:99px;margin-bottom:18px}

.def-box{background:#EBF4FF;border-left:4px solid #4A90D9;border-radius:0 10px 10px 0;padding:14px 18px;margin-bottom:14px}
.def-box p{font-size:13px;color:#1B3F6E;line-height:1.7}
.def-box strong{color:#185FA5;font-weight:700}
.hl-box{background:#1B3F6E;border-radius:10px;padding:13px 18px;margin-top:auto}
.hl-box p{font-size:13px;color:#B8D4F0;line-height:1.65}
.hl-box strong{color:#7EB8F7;font-weight:700}

.igrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.icard{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:11px 13px}
.icard-n{font-size:20px;font-weight:800;color:#4A90D9;margin-bottom:2px}
.icard-l{font-size:12px;font-weight:700;color:#1B3F6E;margin-bottom:2px}
.icard-t{font-size:11px;color:#64748b;line-height:1.5}
.icard.bl{border-left:3px solid #4A90D9;border-radius:0 10px 10px 0}
.icard.gl{border-left:3px solid #3B6D11;border-radius:0 10px 10px 0}
.icard.al{border-left:3px solid #854F0B;border-radius:0 10px 10px 0}
.icard.rl{border-left:3px solid #A32D2D;border-radius:0 10px 10px 0}
.icard.pl{border-left:3px solid #534AB7;border-radius:0 10px 10px 0}
.icard.tl{border-left:3px solid #0F6E56;border-radius:0 10px 10px 0}

.plist{display:flex;flex-direction:column;gap:7px;margin-bottom:14px}
.pitem{display:flex;align-items:flex-start;gap:10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:9px 12px}
.pitem-n{width:24px;height:24px;border-radius:50%;background:#4A90D9;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.pitem h4{font-size:12px;font-weight:700;color:#1B3F6E;margin-bottom:1px}
.pitem p{font-size:11px;color:#64748b;line-height:1.45}

.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.ccard{background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:10px 12px}
.ccard-n{font-size:10px;font-weight:700;color:#4A90D9;margin-bottom:2px;text-transform:uppercase;letter-spacing:0.5px}
.ccard-t{font-size:12px;font-weight:700;color:#1B3F6E;margin-bottom:2px}
.ccard-d{font-size:11px;color:#64748b;line-height:1.4}

.pdca-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.pdca-c{border-radius:9px;padding:12px 14px;text-align:center}
.pdca-c .pl{font-size:12px;font-weight:700;margin-bottom:3px}
.pdca-c .pt{font-size:11px;line-height:1.45}
.pP{background:#EBF4FF}.pP .pl{color:#185FA5}
.pD{background:#EAF3DE}.pD .pl{color:#3B6D11}
.pC{background:#FAEEDA}.pC .pl{color:#854F0B}
.pA{background:#FCEBEB}.pA .pl{color:#A32D2D}

.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.col-h{font-size:13px;font-weight:700;color:#1B3F6E;margin-bottom:8px;padding-bottom:5px;border-bottom:2px solid #4A90D9}
.li{display:flex;align-items:flex-start;gap:7px;font-size:11px;color:#374151;padding:5px 0;border-bottom:1px solid #f1f5f9;line-height:1.45}
.li:last-child{border-bottom:none}
.li-d{width:5px;height:5px;border-radius:50%;background:#4A90D9;flex-shrink:0;margin-top:5px}

.sflow{display:flex;flex-direction:column;gap:0;margin-bottom:14px}
.sfi{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid #f1f5f9}
.sfi:last-child{border-bottom:none}
.sfi-n{width:28px;height:28px;border-radius:50%;background:#4A90D9;color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sfi h4{font-size:12px;font-weight:700;color:#1B3F6E;margin-bottom:2px}
.sfi p{font-size:11px;color:#64748b;line-height:1.45}

.rtable{width:100%;border-collapse:collapse;margin-bottom:14px;font-size:11px}
.rtable th{background:#1B3F6E;color:#fff;padding:7px 10px;text-align:left;font-weight:600;font-size:10px}
.rtable td{padding:7px 10px;border-bottom:1px solid #e2e8f0;color:#374151;line-height:1.45}
.rtable tr:nth-child(even) td{background:#f8fafc}

.acards{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
.acard{background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:11px 14px;border-left:4px solid #4A90D9}
.acard.g{border-left-color:#3B6D11}.acard.a{border-left-color:#854F0B}.acard.r{border-left-color:#A32D2D}
.acard h4{font-size:12px;font-weight:700;color:#1B3F6E;margin-bottom:3px}
.acard p{font-size:11px;color:#64748b;line-height:1.45}

.cert-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px}
.cert-c{background:#f8fafc;border:1px solid #e2e8f0;border-radius:9px;padding:11px 10px;text-align:center}
.cert-n{width:28px;height:28px;border-radius:50%;background:#4A90D9;color:#fff;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 6px}
.cert-c h4{font-size:11px;font-weight:700;color:#1B3F6E;margin-bottom:3px}
.cert-c p{font-size:10px;color:#64748b;line-height:1.35}

.badge-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px}
.badge{font-size:11px;font-weight:700;padding:4px 12px;border-radius:99px}
.b-bl{background:#EBF4FF;color:#185FA5;border:1px solid #B5D4F4}
.b-gr{background:#EAF3DE;color:#3B6D11;border:1px solid #C0DD97}
.b-am{background:#FAEEDA;color:#854F0B;border:1px solid #FAC775}
.b-rd{background:#FCEBEB;color:#A32D2D;border:1px solid #F7C1C1}

/* QUIZ SLIDE */
.sl-quiz{flex:1;padding:24px 28px;display:flex;flex-direction:column;min-height:460px;background:#fff}
.quiz-hdr{background:#1B3F6E;border-radius:10px;padding:16px 20px;margin-bottom:18px}
.quiz-hdr h2{font-size:16px;font-weight:800;color:#fff;margin-bottom:2px}
.quiz-hdr p{font-size:12px;color:#7EB8F7}
.quiz-pbar{height:3px;background:rgba(255,255,255,0.2);border-radius:99px;margin-top:10px}
.quiz-pbf{height:100%;background:#4A90D9;border-radius:99px;transition:width 0.4s}
.q-block{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px 16px;margin-bottom:12px}
.q-num-lbl{font-size:10px;font-weight:700;color:#4A90D9;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:5px}
.q-text{font-size:14px;font-weight:600;color:#1B3F6E;margin-bottom:12px;line-height:1.5}
.q-opts{display:flex;flex-direction:column;gap:7px}
.q-opt{display:flex;align-items:center;gap:9px;background:#fff;border:1.5px solid #e2e8f0;border-radius:8px;padding:9px 13px;cursor:pointer;transition:all 0.2s;font-family:inherit;width:100%;text-align:left}
.q-opt:hover{border-color:#4A90D9;background:#EBF4FF}
.q-opt.ok{background:#EAF3DE;border-color:#3B6D11;color:#27500A}
.q-opt.err{background:#FCEBEB;border-color:#A32D2D;color:#501313}
.q-opt:disabled{cursor:default}
.q-ltr{width:22px;height:22px;border-radius:50%;background:#e2e8f0;color:#64748b;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.q-opt.ok .q-ltr{background:#3B6D11;color:#fff}
.q-opt.err .q-ltr{background:#A32D2D;color:#fff}
.q-opt-txt{font-size:12px;color:#374151}
.q-opt.ok .q-opt-txt,.q-opt.err .q-opt-txt{font-weight:600}
.q-fb{font-size:11px;margin-top:8px;padding:8px 12px;border-radius:7px;display:none;line-height:1.55}
.q-fb.on{display:block}
.q-fb.ok{background:#EAF3DE;color:#27500A;border-left:3px solid #3B6D11}
.q-fb.err{background:#FCEBEB;color:#501313;border-left:3px solid #A32D2D}
.qresult{background:#1B3F6E;border-radius:10px;padding:28px 24px;text-align:center;margin-top:auto}
.qr-pct{font-size:44px;font-weight:800;margin-bottom:4px}
.qr-title{font-size:18px;font-weight:700;color:#fff;margin-bottom:4px}
.qr-sub{font-size:13px;color:#B8D4F0;margin-bottom:16px;line-height:1.6}
.qr-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.qr-btn{background:#4A90D9;color:#fff;border:none;border-radius:99px;padding:9px 22px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit}
.qr-btn:hover{background:#5BA3EC}
.qr-btn.gh{background:transparent;border:1.5px solid #4A90D9;color:#4A90D9}

/* VIDEO SLIDE */
.sl-video{background:#0d1117;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px 32px;min-height:460px;text-align:center}
.sl-video-badge{background:rgba(74,144,217,0.2);border:1px solid #4A90D9;color:#7EB8F7;font-size:11px;font-weight:700;padding:4px 16px;border-radius:99px;letter-spacing:1px;margin-bottom:16px;display:inline-block}
.sl-video-title{font-size:18px;font-weight:800;color:#fff;margin-bottom:20px}
.sl-video-wrap{width:100%;max-width:720px;border-radius:12px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,0.7);border:1px solid #1e3a5f;background:#000}
.sl-video-wrap video{width:100%;display:block;max-height:360px}
.sl-video-sub{font-size:12px;color:#4b6a8a;margin-top:14px}

/* THUMBNAIL STRIP */
.thumb-strip{width:100%;max-width:900px;margin:0 auto;padding:10px 16px 16px;overflow-x:auto;display:flex;gap:7px;-webkit-overflow-scrolling:touch}
.thumb-strip::-webkit-scrollbar{height:3px}
.thumb-strip::-webkit-scrollbar-track{background:transparent}
.thumb-strip::-webkit-scrollbar-thumb{background:#1e3a5f;border-radius:99px}
.thumb{flex-shrink:0;width:80px;cursor:pointer;border-radius:6px;overflow:hidden;border:2px solid transparent;transition:all 0.2s;opacity:0.55}
.thumb:hover{opacity:0.85;border-color:#4A90D9}
.thumb.on{opacity:1;border-color:#4A90D9;box-shadow:0 0 0 2px rgba(74,144,217,0.4)}
.thumb-inner{width:80px;height:52px;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;text-align:center;line-height:1.3;padding:4px 5px;overflow:hidden}
.thumb-label{font-size:9px;text-align:center;padding:2px 4px;background:#0d1117;color:#4b6a8a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
</style>
</head>
<body>

<div class="top-bar">
  <div class="top-logo">ISO <span>9001:2015</span></div>
  <div class="top-unit" id="topUnit">Portada</div>
  <div class="top-prog">
    <div class="top-pbar"><div class="top-pfill" id="topPfill" style="width:0%"></div></div>
    <span class="top-pct" id="topPct">0%</span>
  </div>
</div>

<div class="viewer">
  <div class="slide-display" id="slideDisplay">
    <button class="arr-btn left" id="btnL" onclick="go(-1)" disabled>&#8249;</button>
    <button class="arr-btn right" id="btnR" onclick="go(1)">&#8250;</button>
    <div id="slideContainer" style="width:100%;display:flex;flex-direction:column"></div>
  </div>
</div>

<div class="thumb-strip" id="thumbStrip"></div>

<script>
var slides = [
  /* 0 — VIDEO INTRO */
  {unit:'Introducción', label:'Video', bg:'#0d1117', thumbBg:'#0d1117', thumbColor:'#7EB8F7',
   render: function() {
    return '<div class="sl-video">' +
      '<div class="sl-video-badge">▶ Video Introductorio</div>' +
      '<div class="sl-video-title">Introducción a ISO 9001:2015</div>' +
      '<div class="sl-video-wrap">' +
        '<video controls controlsList="nodownload" preload="metadata">' +
          '<source src="Introducción_a_ISO_9001_2015_720p_caption.mp4" type="video/mp4">' +
          'Tu navegador no soporta el elemento de video.' +
        '</video>' +
      '</div>' +
      '<div class="sl-video-sub">Mira el video y luego avanza para comenzar el curso</div>' +
    '</div>';
   }},

  /* 1 — PORTADA */
  {unit:'Portada', label:'Inicio', bg:'#1B3F6E', thumbBg:'#1B3F6E', thumbColor:'#7EB8F7',
   render: function() {
    return '<div class="sl-portada">' +
      '<div class="sl-portada-badge">Norma Internacional</div>' +
      '<div class="sl-portada-title">ISO <span>9001:2015</span><br>Sistema de Gestión de Calidad</div>' +
      '<div class="sl-portada-sub">Aprende a implementar y comprender los requisitos del estándar internacional de calidad más reconocido del mundo.</div>' +
      '<div class="sl-portada-units">' +
        '<div class="sl-pu"><div class="sl-pu-n">Unidad 1</div><div class="sl-pu-t">Fundamentos y estructura</div></div>' +
        '<div class="sl-pu"><div class="sl-pu-n">Unidad 2</div><div class="sl-pu-t">Requisitos y planificación</div></div>' +
        '<div class="sl-pu"><div class="sl-pu-n">Unidad 3</div><div class="sl-pu-t">Auditoría y certificación</div></div>' +
      '</div>' +
      '<div class="sl-portada-info"><span>3 Unidades</span><span>15 Slides de contenido</span><span>3 Evaluaciones</span></div>' +
    '</div>';
   }},

  /* 1 — INTRO U1 */
  {unit:'Unidad 1', label:'Intro U1', bg:'#1B3F6E', thumbBg:'#1B3F6E', thumbColor:'#fff',
   render: function() {
    return '<div class="sl-intro">' +
      '<div class="sl-intro-line"><div class="sl-intro-bar"></div><div class="sl-intro-num">1</div><div class="sl-intro-bar"></div><div class="sl-intro-dot"></div></div>' +
      '<div class="sl-intro-body">' +
        '<div class="sl-intro-ico"><svg width="60" height="60" viewBox="0 0 60 60" fill="none"><rect x="8" y="6" width="38" height="48" rx="4" fill="#4A90D9" opacity="0.3"/><rect x="8" y="6" width="38" height="48" rx="4" stroke="#7EB8F7" stroke-width="2" fill="none"/><line x1="16" y1="20" x2="38" y2="20" stroke="#7EB8F7" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="28" x2="38" y2="28" stroke="#7EB8F7" stroke-width="2" stroke-linecap="round"/><line x1="16" y1="36" x2="30" y2="36" stroke="#7EB8F7" stroke-width="2" stroke-linecap="round"/><circle cx="48" cy="46" r="10" fill="#1B3F6E" stroke="#4A90D9" stroke-width="2"/><path d="M44 46L47 49L53 43" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>' +
