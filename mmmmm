/* ── HELPERS ── */
function chk(t){return '<div class="sl-intro-obj"><div class="sl-intro-obj-chk"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5L4 7L8 3" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+t+'</div>';}
function cont(tag,title,sub,body){return '<div class="sl-content"><div class="sl-tag">'+tag+'</div><div class="sl-title">'+title+'</div>'+(sub?'<div class="sl-sub">'+sub+'</div>':'')+'<div class="sl-div"></div>'+body+'</div>';}
function def(t){return '<div class="def-box"><p>'+t+'</p></div>';}
function hl(t){return '<div class="hl-box"><p>'+t+'</p></div>';}
function igrid(items){var h='<div class="igrid">';items.forEach(function(c){h+='<div class="icard"><div class="icard-n">'+c.n+'</div><div class="icard-l">'+c.l+'</div><div class="icard-t">'+c.t+'</div></div>';});return h+'</div>';}
function plist(items){var h='<div class="plist">';items.forEach(function(c){h+='<div class="pitem"><div class="pitem-n">'+c.n+'</div><div><h4>'+c.h+'</h4><p>'+c.p+'</p></div></div>';});return h+'</div>';}
function cgrid(items){var h='<div class="cgrid">';items.forEach(function(c){h+='<div class="ccard"><div class="ccard-n">'+c.n+'</div><div class="ccard-t">'+c.t+'</div><div class="ccard-d">'+c.d+'</div></div>';});return h+'</div>';}
function sflow(items){var h='<div class="sflow">';items.forEach(function(c){h+='<div class="sfi"><div class="sfi-n">'+c.n+'</div><div><h4>'+c.h+'</h4><p>'+c.p+'</p></div></div>';});return h+'</div>';}
function li(t){return '<div class="li"><div class="li-d"></div><span>'+t+'</span></div>';}
function certS(n,h,p){return '<div class="cert-c"><div class="cert-n">'+n+'</div><h4>'+h+'</h4><p>'+p+'</p></div>';}

/* ── QUIZ DATA ── */
var quizData = {
  1: {qs:[
    {q:'¿Qué establece la norma ISO 9001:2015?',opts:['El precio de los productos','Los requisitos para un SGC','Los sueldos del personal','El diseño de los procesos'],ans:1,fb:'La ISO 9001:2015 establece los REQUISITOS para un Sistema de Gestión de Calidad, demostrando capacidad de satisfacer al cliente.'},
    {q:'¿Cuántos principios de gestión de calidad define la norma?',opts:['5','6','7','8'],ans:2,fb:'La norma define 7 principios: enfoque en el cliente, liderazgo, compromiso de las personas, procesos, mejora continua, evidencia y relaciones.'},
    {q:'¿Qué significa el ciclo PDCA?',opts:['Plan-Design-Control-Audit','Plan-Do-Check-Act','Process-Document-Control-Assess','Plan-Develop-Certify-Audit'],ans:1,fb:'PDCA = Plan (Planificar) - Do (Hacer) - Check (Verificar) - Act (Actuar). Es el motor de la mejora continua.'},
    {q:'¿A qué organizaciones aplica la ISO 9001:2015?',opts:['Solo a manufactureras','Solo a grandes corporaciones','A organizaciones de cualquier tamaño y sector','Solo a empresas con +50 empleados'],ans:2,fb:'La norma aplica a CUALQUIER organización, independiente de su tamaño, sector o si entrega productos o servicios.'},
    {q:'¿Cuál es la versión actual de la norma ISO 9001?',opts:['ISO 9001:2000','ISO 9001:2008','ISO 9001:2015','ISO 9001:2020'],ans:2,fb:'La versión vigente es ISO 9001:2015, quinta edición, que incorporó el enfoque en riesgos y la estructura HLS.'}
  ]},
  2: {qs:[
    {q:'¿Qué incluye el "contexto de la organización"?',opts:['Solo factores económicos','Solo procesos internos','Factores internos, externos y partes interesadas','Solo requisitos del cliente'],ans:2,fb:'El contexto incluye FACTORES INTERNOS, FACTORES EXTERNOS y las PARTES INTERESADAS relevantes para el SGC.'},
    {q:'¿Qué exige la norma a la alta dirección?',opts:['Delegar toda la responsabilidad','Liderazgo y compromiso activo con el SGC','Solo firmar la política de calidad','Contratar un consultor externo'],ans:1,fb:'La norma exige que la ALTA DIRECCIÓN demuestre liderazgo y compromiso ACTIVO, no solo delegando en el jefe de calidad.'},
    {q:'¿Qué es el "pensamiento basado en riesgos"?',opts:['Un seguro para la empresa','Identificar amenazas y oportunidades que afectan los objetivos del SGC','Calcular el riesgo financiero','Evaluar solo riesgos de seguridad laboral'],ans:1,fb:'Implica IDENTIFICAR, EVALUAR y TRATAR proactivamente tanto amenazas como oportunidades que puedan afectar los objetivos del SGC.'},
    {q:'¿La norma 2015 exige un "manual de calidad"?',opts:['Sí, siempre','No, lo eliminó como requisito obligatorio','Solo para empresas con +100 empleados','Solo para certificaciones internacionales'],ans:1,fb:'La versión 2015 ELIMINÓ el manual de calidad como documento obligatorio. Solo se requiere lo necesario para el funcionamiento del SGC.'},
    {q:'¿Qué cubre la cláusula 8 de la norma?',opts:['Los principios de gestión','Los requisitos de auditoría','El control de los procesos operacionales','La política y objetivos de calidad'],ans:2,fb:'La cláusula 8 (Operación) cubre el CONTROL OPERACIONAL: planificación, requisitos del cliente, control de proveedores y salidas no conformes.'}
  ]},
  3: {qs:[
    {q:'¿Cuál es el propósito de una auditoría interna ISO 9001?',opts:['Castigar al personal','Determinar el grado de cumplimiento del SGC','Solo revisar documentación','Preparar para la auditoría externa'],ans:1,fb:'La auditoría interna es un proceso SISTEMÁTICO E INDEPENDIENTE para evaluar el CUMPLIMIENTO y la EFICACIA del SGC mediante evidencias objetivas.'},
    {q:'¿Cuántas etapas tiene la auditoría de certificación externa?',opts:['Solo una','Dos etapas','Tres etapas','Cuatro etapas'],ans:1,fb:'La auditoría de certificación tiene DOS etapas: Etapa 1 (revisión documental) y Etapa 2 (auditoría en sitio para verificar la implementación).'},
    {q:'¿Cuál es la diferencia entre no conformidad y acción correctiva?',opts:['Son sinónimos','La NC es el incumplimiento; la AC elimina su causa raíz','La AC es el incumplimiento; la NC es la solución','No hay diferencia'],ans:1,fb:'La NO CONFORMIDAD es el incumplimiento detectado. La ACCIÓN CORRECTIVA elimina la CAUSA RAÍZ para que no se repita.'},
    {q:'¿Por cuánto tiempo es válido un certificado ISO 9001?',opts:['1 año','2 años','3 años','5 años'],ans:2,fb:'El certificado ISO 9001 tiene vigencia de 3 AÑOS. Durante ese período se realizan auditorías de vigilancia anuales.'},
    {q:'¿Qué ocurrió con las "acciones preventivas" de la norma 2008?',opts:['Se mantuvieron igual','Se eliminaron completamente','Fueron absorbidas por el pensamiento basado en riesgos','Se convirtieron en correctivas'],ans:2,fb:'En la versión 2015, las acciones preventivas fueron absorbidas por el PENSAMIENTO BASADO EN RIESGOS (cláusula 6).'}
  ]}
};

var qState = {1:{answered:{},score:0}, 2:{answered:{},score:0}, 3:{answered:{},score:0}};

function renderQuiz(u) {
  var d = quizData[u]; var st = qState[u];
  var answered = Object.keys(st.answered).length;
  var pct = answered ? Math.round(answered/d.qs.length*100) : 0;
  var html = '<div class="sl-quiz"><div class="quiz-hdr"><h2>Evaluación — Unidad '+u+'</h2><p>Responde las '+d.qs.length+' preguntas para completar la unidad</p><div class="quiz-pbar"><div class="quiz-pbf" style="width:'+pct+'%"></div></div></div>';
  if (answered < d.qs.length) {
    d.qs.forEach(function(q, i) {
      var ai = st.answered[i];
      var ltrs = ['A','B','C','D'];
      html += '<div class="q-block"><div class="q-num-lbl">Pregunta '+(i+1)+' de '+d.qs.length+'</div><div class="q-text">'+q.q+'</div><div class="q-opts">';
      q.opts.forEach(function(o,j) {
        var cls='', dis = ai!==undefined?'disabled':'';
        if(ai!==undefined){cls=j===q.ans?'ok':(j===ai?'err':'');}
        html+='<button class="q-opt '+cls+'" '+dis+' onclick="ansQ('+u+','+i+','+j+')"><span class="q-ltr">'+ltrs[j]+'</span><span class="q-opt-txt">'+o+'</span></button>';
      });
      var fbcls=ai!==undefined?'on '+(ai===q.ans?'ok':'err'):'';
      html+='</div><div class="q-fb '+fbcls+'">'+(ai!==undefined?(ai===q.ans?'✅ Correcto. ':'❌ Incorrecto. Respuesta correcta: <strong>'+q.opts[q.ans]+'</strong>. ')+q.fb:'')+'</div></div>';
    });
  } else {
    var pctF = Math.round(st.score/d.qs.length*100);
    var passed = pctF>=70;
    var col = passed?'#4ade80':pctF>=50?'#fbbf24':'#f87171';
    html += '<div class="qresult"><div class="qr-pct" style="color:'+col+'">'+pctF+'%</div>' +
      '<div class="qr-title">'+(passed?'¡Aprobado!':'Necesitas repasar')+'</div>' +
      '<div class="qr-sub">'+st.score+' de '+d.qs.length+' correctas<br>'+(passed?'¡Superaste el 70%! Excelente trabajo.':'Menos del 70%. Repasa el contenido e intenta de nuevo.')+'</div>' +
      '<div class="qr-btns"><button class="qr-btn gh" onclick="retryQ('+u+')">Reintentar</button>' +
      (u<3?'<button class="qr-btn" onclick="jumpToSlide('+nextIntroIdx(u)+')">Unidad '+(u+1)+' &#8594;</button>':'<button class="qr-btn" onclick="jumpToSlide(0)">&#8592; Inicio</button>') +
      '</div></div>';
  }
  html += '</div>';
  return html;
}

function nextIntroIdx(u){return u===1?9:15;}

function ansQ(u,qi,ai){
  if(qState[u].answered[qi]!==undefined)return;
  qState[u].answered[qi]=ai;
  if(ai===quizData[u].qs[qi].ans)qState[u].score++;
  renderCurrentSlide();
  scormTrack();
}
function retryQ(u){qState[u]={answered:{},score:0};renderCurrentSlide();}

/* ── NAVIGATION ── */
var cur = 0;
var dir = 1;

function jumpToSlide(n) {
  dir = n > cur ? 1 : -1;
  cur = n;
  renderCurrentSlide();
  updateUI();
  window.scrollTo(0,0);
  scormTrack();
}

function go(d) {
  var next = cur + d;
  if(next<0||next>=slides.length)return;
  dir=d;cur=next;
  renderCurrentSlide();
  updateUI();
  window.scrollTo(0,0);
  scormTrack();
}

function scormTrack() {
  var pct = Math.round(cur / (slides.length - 1) * 100);
  SCORM.setBookmark(cur);
  // Calcular score global combinando progreso + quizzes
  var quizScore = getGlobalQuizScore();
  var combined = Math.round(pct * 0.4 + quizScore * 0.6);
  SCORM.setProgress(combined);
}

function getGlobalQuizScore() {
  var total = 0, answered = 0;
  [1,2,3].forEach(function(u) {
    var d = quizData[u];
    var st = qState[u];
    var cnt = Object.keys(st.answered).length;
    if (cnt === d.qs.length) {
      total += Math.round(st.score / d.qs.length * 100);
      answered++;
    }
  });
  return answered > 0 ? Math.round(total / answered) : 0;
}

function renderCurrentSlide() {
  var s = slides[cur];
  var sc = document.getElementById('slideContainer');
  var html = '';
  if(s.isQuiz) {
    html = renderQuiz(s.isQuiz);
  } else {
    html = '<div class="slide on'+(dir<0?' rev':'')+'" style="background:'+s.bg+'">'+s.render()+'</div>';
  }
  sc.innerHTML = html;
}

function updateUI() {
  var s = slides[cur];
  document.getElementById('btnL').disabled = cur===0;
  document.getElementById('btnR').disabled = cur===slides.length-1;
  document.getElementById('topUnit').textContent = s.unit;
  var pct = Math.round(cur/(slides.length-1)*100);
  document.getElementById('topPfill').style.width = pct+'%';
  document.getElementById('topPct').textContent = pct+'%';
  document.querySelectorAll('.thumb').forEach(function(t,i){t.classList.toggle('on',i===cur);});
  var el = document.querySelector('.thumb.on');
  if(el) el.scrollIntoView({block:'nearest',inline:'center'});
}

/* ── THUMBNAILS ── */
function buildThumbs() {
  var strip = document.getElementById('thumbStrip');
  slides.forEach(function(s,i) {
    var t = document.createElement('div');
    t.className = 'thumb'+(i===0?' on':'');
    var inner = document.createElement('div');
    inner.className = 'thumb-inner';
    inner.style.background = s.thumbBg||'#f8fafc';
    inner.style.color = s.thumbColor||'#1B3F6E';
    if(s.isQuiz){inner.innerHTML='<div style="font-size:16px;margin-bottom:2px">📝</div><div>Quiz U'+s.isQuiz+'</div>';}
    else if(i===0){inner.innerHTML='<div style="font-size:16px;margin-bottom:2px">🏠</div><div>Portada</div>';}
    else{inner.innerHTML='<div>'+s.label+'</div>';}
    var lbl = document.createElement('div');
    lbl.className='thumb-label';lbl.textContent=s.unit;
    t.appendChild(inner);t.appendChild(lbl);
    t.onclick=(function(n){return function(){jumpToSlide(n);};})(i);
    strip.appendChild(t);
  });
}

buildThumbs();
renderCurrentSlide();
updateUI();
</script>
</body>
</html>
